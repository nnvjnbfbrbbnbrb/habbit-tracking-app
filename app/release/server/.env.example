# Get from @BotFather — keep ONLY on the VPS / in .env (never in the Android APK).
TELEGRAM_BOT_TOKEN=

# Optional: random string; pass to setWebhook as secret_token, sent as header
# X-Telegram-Bot-Api-Secret-Token on each webhook request.
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated numeric Telegram user IDs that may control the bot.
ALLOWED_TELEGRAM_USER_IDS=

# Shared secret for YOUR devices calling the HTTP API (Bearer token).
# The APK should contain only this (or a per-device token), not TELEGRAM_BOT_TOKEN.
API_SECRET=

# Telegram user id whose action queue the Android app polls (must be in ALLOWED_TELEGRAM_USER_IDS).
# If unset and you allow exactly one id, that id is used automatically.
DEVICE_QUEUE_TELEGRAM_USER_ID=

# Bind address for uvicorn
HOST=0.0.0.0
PORT=8000

# If true, call Telegram getUpdates in-process (good for local dev without HTTPS).
# If false, use POST /telegram/webhook behind HTTPS (production).
USE_POLLING=false

# SQLite path for the device action queue (relative to server working directory).
QUEUE_DB_PATH=data/actions.db

# Optional: Android control server base URL (no trailing slash), e.g. http://100.53.27.75:3000
# Used by Telegram admin commands /app_on, /users, /broadcast, etc. (proxied from the bridge).
CONTROL_SERVER_URL=

# SQLite for bridge-local admin data (audit logs, reminders, habit snapshot for /habits).
ADMIN_DB_PATH=data/admin.db
